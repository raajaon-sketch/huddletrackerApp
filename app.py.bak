@app.route('/api/users', methods=['POST'])
@login_required
def create_user():
    try:
        if current_user.role != 'admin':
            return jsonify({'error': 'Unauthorized'}), 403
        data = request.get_json(silent=True) or {}
        if User.query.filter_by(username=data.get('username')).first():
            return jsonify({'error': 'Username already exists'}), 409
        # FIX-10: Basic email format validation
        email_val = data.get('email', '')
        if not re.match(r'^[^@\s]+@[^@\s]+\.[^@\s]+$', email_val):
            return jsonify({'error': 'Invalid email format'}), 400
        if User.query.filter_by(email=email_val).first():
            return jsonify({'error': 'Email already registered'}), 409
        u = User(
            username=sanitize(data['username'])[:80],
            email=sanitize(data['email'])[:120],
            enterprise_id=sanitize(data['enterprise_id'])[:50],
            role=data.get('role', 'member'),
        )
        u.set_password(data['password'])
        db.session.add(u)
        db.session.commit()
        return jsonify(u.to_dict()), 201
    except Exception as e:
        db.session.rollback()
        return jsonify({'error': str(e)}), 500


# ── Analytics API ──────────────────────────────────────────────────────────────

@app.route('/api/analytics', methods=['GET'])
@login_required
def analytics():
    try:
        # BUG-05 FIX: Scope analytics to the requesting user's tasks for members.
        # Admins and leads continue to see org-wide figures.
        if current_user.role == 'member':
            base = Task.query.filter(db.or_(
                Task.assigned_to == current_user.id,
                Task.created_by  == current_user.id,
            ))
            projs = db.session.query(Task.project_id).filter(
                db.or_(Task.assigned_to == current_user.id,
                       Task.created_by  == current_user.id)
            ).distinct().count()
            # Scoped volume: only this user's tasks
            vol = db.session.query(db.func.sum(Task.volume)).filter(
                db.or_(Task.assigned_to == current_user.id,
                       Task.created_by  == current_user.id)
            ).scalar() or 0
        else:
            base  = Task.query
            projs = Project.query.count()
            vol   = db.session.query(db.func.sum(Task.volume)).scalar() or 0

        # BUG-FIX: Use filter(Task.col == val) instead of filter_by() chained on
        # the same `base` variable. filter_by() mutates / chains the existing query
        # object in SQLAlchemy, so repeated calls accumulate extra WHERE clauses and
        # produce incorrect counts (e.g. done count bleeds into pending count).
        total = base.count()
        done  = base.filter(Task.status == 'done').count()
        pend  = base.filter(Task.status == 'pending').count()
        inp   = base.filter(Task.status == 'in_progress').count()
        blk   = base.filter(Task.status == 'blocked').count()
        comp  = base.filter(
            Task.started_at.isnot(None),
            Task.completed_at.isnot(None),
        ).all()
        avg = (
            round(sum((t.completed_at - t.started_at).total_seconds() / 3600
                      for t in comp) / len(comp), 1)
            if comp else 0
        )
        pdata = {p: base.filter(Task.priority == p).count()
                 for p in ('low', 'medium', 'high', 'critical')}

        # Total active users (admin dashboard "Team Members" stat card)
        total_users = User.query.filter_by(is_active=True).count()

        return jsonify({
            'total_tasks': total, 'done_tasks': done, 'pending_tasks': pend,
            'in_progress': inp, 'blocked': blk, 'total_projects': projs,
            'total_volume': vol, 'avg_tat_hours': avg, 'priority_data': pdata,
            'completion_rate': round(done / total * 100, 1) if total else 0,
            'total_users': total_users,
        })
    except Exception as e:
        return jsonify({'error': str(e)}), 500


