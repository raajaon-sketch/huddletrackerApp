<!-- IMPORT MODAL -->
<div class="overlay" id="mImport">
  <div class="modal modal-lg">
    <div class="mh"><span class="mt">Import Task Names</span><button class="mc" onclick="closeModal('mImport');resetImp()">&#215;</button></div>
    <div class="mb">
      <div id="iStep1">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:13px">
          <div style="font-size:.83rem;color:var(--muted)">Columns required: <strong>Mapping Process, Tasks, Cap Timings</strong></div>
          <button class="btn btn-outline btn-sm" onclick="location.href='/api/task-names/template'">&#8595; Template</button>
        </div>
        <div class="imp-zone" id="iZone" onclick="document.getElementById('iFile').click()"
             ondragover="event.preventDefault();this.classList.add('drag')"
             ondragleave="this.classList.remove('drag')"
             ondrop="iDrop(event)">
          <div style="font-size:2rem;margin-bottom:8px">&#128194;</div>
          <div style="font-weight:600;margin-bottom:4px">Click to browse or drag &amp; drop</div>
          <div style="font-size:.78rem;color:var(--muted)">.xlsx files only</div>
        </div>
        <input type="file" id="iFile" accept=".xlsx" style="display:none" onchange="iHandle(this.files[0])">
      </div>
      <div id="iStep2" style="display:none">
        <div class="imp-result" id="iResult"></div>
        <div style="font-family:'Syne',sans-serif;font-weight:700;margin-bottom:9px" id="iLabel"></div>
        <div class="prev-wrap">
          <table><thead><tr><th>#</th><th>Mapping Process</th><th>Task Name</th><th>Cap (mins)</th><th>Valid?</th></tr></thead>
          <tbody id="iPrev"></tbody></table>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:8px">
          <button class="btn btn-outline btn-sm" onclick="resetImp()">&#8592; Back</button>
          <div style="display:flex;gap:8px;align-items:center">
            <span id="iVC" style="font-size:.8rem;color:var(--muted)"></span>
            <button class="btn btn-success btn-sm" id="iCBtn" onclick="doImport()">&#10003; Import</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>
<script>
/* XSS-FIX: HTML-escape helper — always wrap untrusted data injected into innerHTML */
function escHtml(s){if(s==null)return '';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');}
let allTN=[],impRows=[];

/* helpers */
function toast(m,t='success'){
  const el=document.getElementById('toast');
  el.textContent=(t==='success'?'✅ ':'❌ ')+m;
  el.className='toast show';
  setTimeout(()=>el.className='toast',3000);
}
function openModal(id){
  const ov = document.getElementById(id);
  ov.classList.add('open');
  const box = ov.querySelector('.modal');
  if(box && !box._spBound){
    box.addEventListener('mousedown', e => e.stopPropagation());
    box._spBound = true;
  }
}
function closeModal(id){document.getElementById(id).classList.remove('open');}
function bdg(v){if(!v)return '<span class="badge badge-unknown">—</span>';return `<span class="badge badge-${v}">${v.replace('_',' ')}</span>`;}
async function api(u,m='GET',b=null){
  const o={method:m,headers:{'Content-Type':'application/json','X-CSRF-Token':document.querySelector('meta[name="csrf-token"]')?.content||''}};
  if(b)o.body=JSON.stringify(b);
  return await fetch(u,o);
}

/* nav */
const TITLES={dashboard:'Dashboard',tasks:'All Tasks',users:'Users',analytics:'Analytics',tasknames:'Task Names'};
function show(name){
  try{
    document.querySelectorAll('.vs').forEach(el=>el.classList.remove('active'));
    document.querySelectorAll('.ni').forEach(el=>el.classList.remove('active'));
    const vs=document.getElementById('vs-'+name);
    if(!vs){console.error('Missing section: vs-'+name);return;}
    vs.classList.add('active');
    // BUG-FIX: use data-view attribute for reliable active highlighting
    // instead of fragile text-content substring matching
    const ni=document.querySelector(`.ni[data-view="${name}"]`);
    if(ni) ni.classList.add('active');
    const pgTitle=document.getElementById('pgTitle');
    if(pgTitle) pgTitle.textContent=TITLES[name]||name;
    ['bNewUser','bImpTN','bAddTN','bTaskExport'].forEach(id=>{const e=document.getElementById(id);if(e)e.style.display='none';});
    if(name==='users'){const e=document.getElementById('bNewUser');if(e)e.style.display='';}
    if(name==='tasknames'){
      const i=document.getElementById('bImpTN');const a=document.getElementById('bAddTN');
      if(i)i.style.display='';if(a)a.style.display='';
    }
    if(name==='tasks'){const e=document.getElementById('bTaskExport');if(e)e.style.display='';}
    if(name==='dashboard')loadDash();
    else if(name==='tasks')loadAllTasksPage();
    else if(name==='users')loadUsers();
    else if(name==='analytics')loadAnalytics();
    else if(name==='tasknames'){loadProcesses();loadTN();}
  }catch(e){console.error('show() error:',e);}
}

/* DASHBOARD */
async function loadDash(){
  // PERF: fetch analytics only — task table removed from dashboard
  const r = await api('/api/analytics');
  const d = await r.json();
  document.getElementById('dStats').innerHTML=[
    {l:'Total Tasks',v:d.total_tasks,c:'--accent'},
    {l:'Completed',v:d.done_tasks,c:'--green'},
    {l:'In Progress',v:d.in_progress,c:'--blue'},
    {l:'Total Volume',v:d.total_volume,c:'--purple'},
    {l:'Team Members',v:d.total_users||'—',c:'--gold'},
    {l:'Avg TAT (mins)',v:d.avg_tat_mins,c:'--yellow'},
    {l:'Completion %',v:d.completion_rate+'%',c:'--green'},
    {l:'Blocked',v:d.blocked,c:'--red'},
  ].map(s=>`<div class="stat-card" style="--c:var(${s.c})"><div class="stat-value">${s.v}</div><div class="stat-label">${s.l}</div></div>`).join('');
  const C=251,tot=d.total_tasks||1;let off=0;
  [{id:'cDone',v:d.done_tasks},{id:'cPend',v:d.pending_tasks},{id:'cInpro',v:d.in_progress}].forEach(s=>{
    const el=document.getElementById(s.id);const len=(s.v/tot)*C;
    el.setAttribute('stroke-dasharray',`${len} ${C-len}`);
    el.setAttribute('stroke-dashoffset',-off);off+=len;
  });
  document.getElementById('dPct').textContent=d.completion_rate+'%';
  const pC={low:'#94a3b8',medium:'#eab308',high:'#f97316',critical:'#ef4444'};
  const pM=Math.max(...Object.values(d.priority_data),1);
  document.getElementById('dPriority').innerHTML=Object.entries(d.priority_data).map(([k,v])=>
    `<div style="margin-bottom:12px">
       <div style="display:flex;justify-content:space-between;font-size:.78rem;margin-bottom:5px">
         <span style="text-transform:capitalize;font-weight:500">${k}</span><span style="color:var(--muted)">${v}</span>
       </div>
       <div class="pb"><div class="pf" style="width:${(v/pM*100).toFixed(1)}%;background:${pC[k]}"></div></div>
     </div>`).join('');
}



/* ═══════════════════════════════════════════════════════════════
   ALL TASKS PAGE
═══════════════════════════════════════════════════════════════ */
let atTasks = [];
let atAllUsers = [];
let atSortCol = '';
let atSortDir = 1;

async function loadAllTasksPage() {
  const tbody = document.getElementById('atTbody');
  if (tbody) tbody.innerHTML = '<tr><td colspan="12"><div class="empty"><div class="ei">⏳</div>Loading…</div></td></tr>';

  try {
    const [tasksRes, usersRes] = await Promise.all([api('/api/tasks'), api('/api/users')]);
    const [tasks, users] = await Promise.all([tasksRes.json(), usersRes.json()]);
    atTasks = tasks;
    atAllUsers = users;

    // Populate assignee dropdown in edit modal
    const sel = document.getElementById('etAssignee');
    if (sel) {
      sel.innerHTML = '<option value="">— Select Assignee —</option>' +
        users.map(u => `<option value="${u.id}">${escHtml(u.username)} (${escHtml(u.enterprise_id)})</option>`).join('');
    }

    // Populate process filter
    const procs = [...new Set(tasks.map(t => t.process).filter(Boolean))].sort();
    const pf = document.getElementById('atf_process');
    if (pf) {
      const cur = pf.value;
      pf.innerHTML = '<option value="">All Mapping Processes</option>' +
        procs.map(p => `<option value="${escHtml(p)}"${cur===p?' selected':''}>${escHtml(p)}</option>`).join('');
    }

    renderAT();
  } catch (e) {
    toast('Failed to load tasks', 'error');
    console.error(e);
  }
}

function renderAT() {
  const fStudy    = (document.getElementById('atf_study')?.value    || '').toLowerCase();
  const fSrRfc    = (document.getElementById('atf_srrfc')?.value    || '').toLowerCase();
  const fTask     = (document.getElementById('atf_task')?.value     || '').toLowerCase();
  const fProcess  =  document.getElementById('atf_process')?.value  || '';
  const fAssignee = (document.getElementById('atf_assignee')?.value || '').toLowerCase();
  const fEntId    = (document.getElementById('atf_entid')?.value    || '').toLowerCase();
  const fStatus   =  document.getElementById('atf_status')?.value   || '';
  const fPriority =  document.getElementById('atf_priority')?.value || '';
  const fDue      =  document.getElementById('atf_due')?.value      || '';

  let rows = atTasks.filter(t =>
    (!fStudy    || (t.study_id    ||'').toLowerCase().includes(fStudy))    &&
    (!fSrRfc    || (t.sr_rfc      ||'').toLowerCase().includes(fSrRfc))    &&
    (!fTask     || (t.task_name   ||'').toLowerCase().includes(fTask))     &&
    (!fProcess  || t.process === fProcess)                                  &&
    (!fAssignee || (t.assignee_name||'').toLowerCase().includes(fAssignee))&&
    (!fEntId    || (t.enterprise_id||'').toLowerCase().includes(fEntId)) &&
    (!fStatus   || t.status   === fStatus)   &&
    (!fPriority || t.priority === fPriority) &&
    (!fDue      || (t.due_date||'').startsWith(fDue))
  );

  if (atSortCol) {
    rows.sort((a,b) => {
      const av = a[atSortCol] || '', bv = b[atSortCol] || '';
      return typeof av === 'number'
        ? (av - bv) * atSortDir
        : String(av).localeCompare(String(bv)) * atSortDir;
    });
  }

  const countEl = document.getElementById('atCount');
  if (countEl) countEl.textContent = `${rows.length} of ${atTasks.length} tasks`;

  const tbody = document.getElementById('atTbody');
  if (!tbody) return;
  if (!rows.length) {
    tbody.innerHTML = '<tr><td colspan="12"><div class="empty"><div class="ei">📋</div>No tasks match filters</div></td></tr>';
    return;
  }

  tbody.innerHTML = rows.map(t => `<tr>
    <td class="mono" style="font-size:.72rem">${escHtml(t.study_id)||'—'}</td>
    <td style="font-size:.78rem">${escHtml(t.sr_rfc)||'—'}</td>
    <td><span class="pchip" style="font-size:.68rem">${escHtml(t.process)||'—'}</span></td>
    <td style="max-width:160px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500"
        title="${escHtml(t.task_name)}">${escHtml(t.task_name)}</td>
    <td style="font-size:.8rem">${escHtml(t.assignee_name)||'—'}</td>
    <td style="font-size:.75rem;color:var(--muted)">${escHtml(t.enterprise_id)||'—'}</td>
    <td style="font-size:.8rem;text-align:center">${t.turnaround_time!=null?t.turnaround_time:'—'}</td>
    <td style="font-size:.8rem;text-align:center">${t.volume!=null?t.volume:'—'}</td>
    <td style="font-size:.75rem;color:var(--muted)">${escHtml(t.due_date)||'—'}</td>
    <td>${bdg(t.status)}</td>
    <td>${bdg(t.priority)}</td>
    <td style="text-align:center;white-space:nowrap;">
      <button class="btn btn-outline btn-sm" style="padding:4px 9px;font-size:.72rem;margin-right:3px;"
              onclick="atOpenEdit(${t.id})" title="Edit task">✏️</button>
      <button class="btn btn-danger btn-sm" style="padding:4px 9px;font-size:.72rem;"
              data-delid="${t.id}" data-delname="${escHtml(t.task_name)}" data-delstudy="${escHtml(t.study_id||'')}"
              onclick="atOpenDelete(this)" title="Delete task">🗑</button>
    </td>
  </tr>`).join('');
}

function atSort(col) {
  if (atSortCol === col) atSortDir *= -1;
  else { atSortCol = col; atSortDir = 1; }
  document.querySelectorAll('[id^="ats_"]').forEach(el => el.textContent = '');
  const ind = document.getElementById('ats_' + col);
  if (ind) ind.textContent = atSortDir === 1 ? ' ▲' : ' ▼';
  renderAT();
}

function atClearFilters() {
  ['atf_study','atf_srrfc','atf_task','atf_assignee','atf_entid','atf_due'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  ['atf_process','atf_status','atf_priority'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  atSortCol = ''; atSortDir = 1;
  document.querySelectorAll('[id^="ats_"]').forEach(el => el.textContent = '');
  renderAT();
}

function atOpenEdit(id) {
  const t = atTasks.find(x => x.id === id);
  if (!t) return;
  document.getElementById('etId').value      = t.id;
  document.getElementById('etStudyId').value = t.study_id || '';
  document.getElementById('etSrRfc').value   = t.sr_rfc   || '';
  document.getElementById('etProcess').value = t.process  || '';
  document.getElementById('etTaskName').value= t.task_name|| '';
  document.getElementById('etSubtask').value = t.subtask  || '';
  document.getElementById('etTAT').value     = t.turnaround_time || '';
  document.getElementById('etVol').value     = t.volume   || 1;
  document.getElementById('etNotes').value   = t.notes    || '';
  document.getElementById('etDue').value     = t.due_date ? t.due_date.substring(0,10) : '';
  document.getElementById('etStarted').value = t.started_at ? t.started_at.substring(0,10) : '';

  // Set status select
  const statSel = document.getElementById('etStat');
  if (statSel) [...statSel.options].forEach(o => o.selected = o.value === t.status);

  // Set priority select
  const priSel = document.getElementById('etPri');
  if (priSel) [...priSel.options].forEach(o => o.selected = o.value === t.priority);

  // Set assignee
  const asgSel = document.getElementById('etAssignee');
  if (asgSel) [...asgSel.options].forEach(o => o.selected = parseInt(o.value) === t.assigned_to);

  openModal('mEditTask');
}

async function atSaveEdit() {
  const id  = parseInt(document.getElementById('etId').value);
  const tat = parseInt(document.getElementById('etTAT').value);
  const vol = parseInt(document.getElementById('etVol').value);

  if (!document.getElementById('etAssignee').value) { toast('Please select an assignee', 'error'); return; }
  if (!tat || tat < 1)  { toast('Turnaround time must be at least 1 min', 'error'); return; }
  if (!document.getElementById('etDue').value)       { toast('Due date is required', 'error'); return; }

  const body = {
    sr_rfc:          document.getElementById('etSrRfc').value.trim(),
    subtask:         document.getElementById('etSubtask').value.trim(),
    assigned_to:     parseInt(document.getElementById('etAssignee').value),
    priority:        document.getElementById('etPri').value,
    turnaround_time: tat,
    volume:          vol || 1,
    due_date:        document.getElementById('etDue').value,
    started_at:      document.getElementById('etStarted').value || null,
    status:          document.getElementById('etStat').value,
    notes:           document.getElementById('etNotes').value.trim(),
  };

  try {
    const res = await api(`/api/tasks/${id}`, 'PUT', body);
    if (res.ok) {
      toast('Task updated ✓');
      closeModal('mEditTask');
      await loadAllTasksPage();
    } else {
      const d = await res.json();
      toast(d.error || 'Save failed', 'error');
    }
  } catch (e) {
    toast('Network error', 'error');
    console.error(e);
  }
}

function atOpenDelete(btnOrId, desc) {
  // Accept both atOpenDelete(btn) from data-attrs and atOpenDelete(id, desc) legacy
  if (btnOrId && typeof btnOrId === 'object' && btnOrId.dataset) {
    const btn = btnOrId;
    document.getElementById('delTaskId').value       = btn.dataset.delid;
    document.getElementById('delTaskDesc').textContent =
      (btn.dataset.delname || '—') + (btn.dataset.delstudy ? ' — ' + btn.dataset.delstudy : '');
  } else {
    document.getElementById('delTaskId').value       = btnOrId;
    document.getElementById('delTaskDesc').textContent = desc || '';
  }
  openModal('mDelTask');
}

async function atConfirmDelete() {
  const id = parseInt(document.getElementById('delTaskId').value);
  try {
    const res = await api(`/api/tasks/${id}`, 'DELETE');
    if (res.ok) {
      toast('Task deleted');
      closeModal('mDelTask');
      await loadAllTasksPage();
    } else {
      const d = await res.json();
      toast(d.error || 'Delete failed', 'error');
    }
  } catch (e) {
    toast('Network error', 'error');
    console.error(e);
  }
}

function exportAllTasksPage() {
  if (!atTasks.length) { toast('No tasks to export', 'error'); return; }
  window.location.href = '/api/tasks/export';
  toast('Exporting tasks…');
}


/* USERS */
async function loadUsers(){
  const panel = document.getElementById('usersPanel');
  const header = document.getElementById('uActivityHeader');
  const dayLabels = document.getElementById('uDayLabels');
  const uCount = document.getElementById('uCount');

  panel.innerHTML = '<div style="padding:24px;text-align:center;color:var(--muted);font-size:.83rem;">Loading…</div>';

  try {
    // Fetch activity data (admin/lead only endpoint)
    const resp = await api('/api/users/activity');
    const data = await resp.json();

    // If endpoint returned an error or non-array, fall back to /api/users
    if (!resp.ok || !Array.isArray(data)) {
      console.warn('Activity endpoint unavailable, falling back to /api/users:', data);
      const r2 = await api('/api/users');
      const users = await r2.json();
      if (!Array.isArray(users) || !users.length) {
        panel.innerHTML = '<div class="empty"><div>No users found</div></div>';
        header.style.display = 'none';
        return;
      }
      // Render without activity data
      const cols = ['#ff4d2e','#22c55e','#3b82f6','#a855f7','#eab308','#f97316','#06b6d4','#ec4899'];
      header.style.display = 'none';
      uCount.textContent = `${users.length} member${users.length!==1?'s':''}`;
      panel.innerHTML = users.map((u,i) => `<div class="urow" style="${u.is_active?'':'opacity:.5'}">
        <div class="uav" style="background:${cols[i%cols.length]}">${escHtml(u.username[0].toUpperCase())}</div>
        <div class="u-info">
          <div class="u-name">${escHtml(u.username)}${u.is_active?'':' <span style="font-size:.68rem;color:var(--muted)">(inactive)</span>'}</div>
          <div class="u-meta">${escHtml(u.enterprise_id)} &middot; ${escHtml(u.email)} &middot; <span style="text-transform:capitalize">${escHtml(u.role)}</span></div>
        </div>
        ${bdg(u.role)}
        <button class="btn btn-outline btn-sm edit-user-btn" style="margin-left:6px;flex-shrink:0;"
          data-uid="${u.id}" data-username="${escHtml(u.username)}"
          data-role="${escHtml(u.role)}" data-active="${u.is_active}" data-email="${escHtml(u.email)}">&#9998; Edit</button>
      </div>`).join('');
      document.querySelectorAll('.edit-user-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          openEditUser(btn.dataset.uid, btn.dataset.username, btn.dataset.role, btn.dataset.active==='true', btn.dataset.email);
        });
      });
      return;
    }

    if (!data.length) {
      panel.innerHTML = '<div class="empty"><div>No users found</div></div>';
      header.style.display = 'none';
      return;
    }

    // Build day column header labels from first user's activity
    const days = data[0].activity;
    const dayNames = ['Today', 'Yesterday', '2 Days Ago'];
    dayLabels.innerHTML = days.map((d,i) => `
      <div class="u-day">
        <span class="u-day-lbl" style="${i===0?'color:var(--gold);font-weight:700;':''}">${dayNames[i]}</span>
        <span style="font-size:.6rem;color:var(--muted)">${d.label}</span>
      </div>`).join('');
    header.style.display = 'flex';
    uCount.textContent = `${data.length} member${data.length!==1?'s':''}`;

    const cols = ['#ff4d2e','#22c55e','#3b82f6','#a855f7','#eab308','#f97316','#06b6d4','#ec4899'];

    panel.innerHTML = data.map((u, i) => {
      const activityHtml = u.activity.map((d, di) => {
        const isToday = di === 0;
        const cls = d.count > 0 ? (isToday ? 'today-has' : 'has-tasks') : 'no-tasks';
        return `<div class="u-day"><span class="u-day-pill ${cls}" title="${d.count} task${d.count!==1?'s':''} submitted on ${d.label}">${d.count}</span></div>`;
      }).join('');
      return `<div class="urow" style="${u.is_active?'':'opacity:.5'}">
        <div class="uav" style="background:${cols[i%cols.length]}">${escHtml(u.username[0].toUpperCase())}</div>
        <div class="u-info">
          <div class="u-name">${escHtml(u.username)}${u.is_active?'':' <span style="font-size:.68rem;color:var(--muted)">(inactive)</span>'}</div>
          <div class="u-meta">${escHtml(u.enterprise_id)} &middot; ${escHtml(u.email)} &middot; <span style="text-transform:capitalize">${escHtml(u.role)}</span></div>
        </div>
        ${bdg(u.role)}
        <div class="u-activity">${activityHtml}</div>
        <button class="btn btn-outline btn-sm edit-user-btn" style="margin-left:6px;flex-shrink:0;"
          data-uid="${u.id}" data-username="${escHtml(u.username)}"
          data-role="${escHtml(u.role)}" data-active="${u.is_active}" data-email="${escHtml(u.email)}">&#9998; Edit</button>
      </div>`;
    }).join('');

    document.querySelectorAll('.edit-user-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        openEditUser(btn.dataset.uid, btn.dataset.username, btn.dataset.role, btn.dataset.active==='true', btn.dataset.email);
      });
    });

  } catch(e) {
    console.error('loadUsers error:', e);
    // Last-resort fallback: try plain /api/users
    try {
      const r2 = await api('/api/users');
      const users = await r2.json();
      if (Array.isArray(users) && users.length) {
        header.style.display = 'none';
        uCount.textContent = `${users.length} member${users.length!==1?'s':''}`;
        const cols = ['#ff4d2e','#22c55e','#3b82f6','#a855f7','#eab308','#f97316','#06b6d4','#ec4899'];
        panel.innerHTML = users.map((u,i) => `<div class="urow" style="${u.is_active?'':'opacity:.5'}">
          <div class="uav" style="background:${cols[i%cols.length]}">${escHtml(u.username[0].toUpperCase())}</div>
          <div class="u-info">
            <div class="u-name">${escHtml(u.username)}</div>
            <div class="u-meta">${escHtml(u.enterprise_id)} &middot; ${escHtml(u.email)}</div>
          </div>
          ${bdg(u.role)}
          <button class="btn btn-outline btn-sm edit-user-btn" style="margin-left:6px;flex-shrink:0;"
            data-uid="${u.id}" data-username="${escHtml(u.username)}"
            data-role="${escHtml(u.role)}" data-active="${u.is_active}" data-email="${escHtml(u.email)}">&#9998; Edit</button>
        </div>`).join('');
        document.querySelectorAll('.edit-user-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            openEditUser(btn.dataset.uid, btn.dataset.username, btn.dataset.role, btn.dataset.active==='true', btn.dataset.email);
          });
        });
        return;
      }
    } catch(e2) { console.error('fallback also failed:', e2); }
    panel.innerHTML = '<div class="empty"><div>Failed to load users</div></div>';
    header.style.display = 'none';
  }
}
function openEditUser(id, username, role, isActive, email){
  document.getElementById('eUserId').value=id;
  document.getElementById('euName').value=username;
  document.getElementById('euRole').value=role;
  document.getElementById('euActive').value=String(isActive);
  document.getElementById('euEmail').value=email;
  document.getElementById('euPass').value='';
  openModal('mEditUser');
}
async function saveUserEdit(){
  const id=document.getElementById('eUserId').value;
  const body={role:document.getElementById('euRole').value,
    is_active:document.getElementById('euActive').value==='true',
    email:document.getElementById('euEmail').value.trim()};
  const pw=document.getElementById('euPass').value;
  if(pw)body.password=pw;
  const r=await api(`/api/users/${id}`,'PUT',body);
  if(r.ok){toast('User updated');closeModal('mEditUser');loadUsers();}
  else{const d=await r.json();toast(d.error||'Failed','error');}
}
function clearUserForm(){
  document.getElementById('uName').value='';
  document.getElementById('uEid').value='';
  document.getElementById('uEmail').value='';
  document.getElementById('uPass').value='';
  document.getElementById('uRole').value='member';
}
function openNewUser(){
  clearUserForm();
  openModal('mUser');
}
async function saveUser(){
  const body={username:document.getElementById('uName').value.trim(),email:document.getElementById('uEmail').value.trim(),
    enterprise_id:document.getElementById('uEid').value.trim(),password:document.getElementById('uPass').value,
    role:document.getElementById('uRole').value};
  if(!body.username||!body.email||!body.enterprise_id||!body.password){toast('All fields required','error');return;}
  const r=await api('/api/users','POST',body);
  if(r.ok){toast('User created');clearUserForm();closeModal('mUser');loadUsers();}
  else{const d=await r.json();toast(d.error||'Failed','error');}
}

/* ANALYTICS */
let calYear=0, calMonth=0, calDayData={}, calSelected='';

async function loadAnalytics(){
  const now=new Date();
  if(!calYear){calYear=now.getFullYear();calMonth=now.getMonth()+1;}
  // PERF: fetch analytics and tasks in parallel
  const r = await api('/api/analytics');
  const d = await r.json();
  document.getElementById('aStats').innerHTML=[
    {l:'Completion Rate',v:d.completion_rate+'%',c:'--green'},
    {l:'Avg TAT (mins)',v:d.avg_tat_mins,c:'--blue'},
    {l:'Total Volume',v:d.total_volume,c:'--purple'},
    {l:'Blocked Tasks',v:d.blocked,c:'--red'},
  ].map(s=>`<div class="stat-card" style="--c:var(${s.c})"><div class="stat-value">${s.v}</div><div class="stat-label">${s.l}</div></div>`).join('');
  const pC={low:'#94a3b8',medium:'#eab308',high:'#f97316',critical:'#ef4444'};
  const pM=Math.max(...Object.values(d.priority_data),1);
  document.getElementById('aPriority').innerHTML=Object.entries(d.priority_data).map(([k,v])=>
    `<div style="margin-bottom:13px">
       <div style="display:flex;justify-content:space-between;font-size:.83rem;margin-bottom:5px">
         <span style="font-weight:500;text-transform:capitalize">${k}</span><span style="color:var(--muted)">${v} tasks</span>
       </div>
       <div class="pb" style="height:8px"><div class="pf" style="width:${(v/pM*100).toFixed(1)}%;background:${pC[k]}"></div></div>
     </div>`).join('');
  document.getElementById('aMetrics').innerHTML=`<div style="display:grid;gap:0">
    ${[['📋','Total Tasks',d.total_tasks],['✅','Done',d.done_tasks],['⏳','Pending',d.pending_tasks],
       ['🔄','In Progress',d.in_progress],['🚫','Blocked',d.blocked],['📦','Total Volume',d.total_volume]]
      .map(([i,l,v])=>`<div style="display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--border)">
        <span style="font-size:.83rem">${i} ${l}</span><strong style="font-family:'Syne',sans-serif;font-size:.95rem">${v}</strong></div>`).join('')}</div>`;
  await loadCalMonth();

  // TAT Overload Warnings
  try{
    const wr=await api('/api/analytics/tat-warnings');
    const wd=await wr.json();
    const warns=wd.warnings||[];
    const panel=document.getElementById('aTatWarnPanel');
    const ph=document.getElementById('aTatWarnPh');
    const title=document.getElementById('aTatWarnTitle');
    const sub=document.getElementById('aTatWarnSub');
    const cont=document.getElementById('aTatWarn');
    if(!warns.length){
      panel.style.border='1.5px solid #86efac';
      ph.style.background='#f0fdf4';ph.style.borderBottomColor='#86efac';
      title.style.color='#15803d';title.textContent='✅ No TAT Overloads';
      sub.style.color='#15803d';sub.textContent='All members are within the 540 min daily limit';
      cont.innerHTML='<div style="color:var(--muted);font-size:.85rem;padding:4px 0">No members exceeded 540 mins TAT on any single day.</div>';
      return;
    }
    panel.style.border='1.5px solid #fca5a5';
    ph.style.background='#fff5f5';ph.style.borderBottomColor='#fca5a5';
    title.style.color='#b91c1c';title.textContent='⚠️ TAT Overload Warnings';
    sub.style.color='#b91c1c';sub.textContent='Members exceeding 540 mins (9 hrs) TAT on a single day';
    cont.innerHTML=warns.map(w=>{
      const overBy=w.over_by_mins;
      const pct=Math.min(100,Math.round((w.total_mins/540)*100));
      const barCol=w.total_mins>720?'#ef4444':w.total_mins>600?'#f97316':'#eab308';
      return `<div style="background:#fff8f8;border:1px solid #fecaca;border-radius:10px;padding:14px 16px;margin-bottom:12px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:6px">
          <div style="display:flex;align-items:center;gap:10px">
            <div style="width:34px;height:34px;border-radius:9px;background:#fecaca;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;color:#b91c1c">${escHtml(w.member[0].toUpperCase())}</div>
            <div>
              <div style="font-weight:600;font-size:.92rem">${escHtml(w.member)}</div>
              <div style="font-size:.74rem;color:var(--muted)">${escHtml(w.enterprise_id)}</div>
            </div>
          </div>
          <div style="text-align:right">
            <div style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.05rem;color:#b91c1c">${w.total_mins} mins <span style="font-size:.75rem;font-weight:500">(${w.total_hrs} hrs)</span></div>
            <div style="font-size:.72rem;color:#b91c1c;font-weight:500">+${overBy} mins over limit · ${escHtml(w.date)}</div>
          </div>
        </div>
        <div style="background:#fee2e2;border-radius:6px;height:7px;margin-bottom:10px;overflow:hidden">
          <div style="height:100%;width:${pct}%;background:${barCol};border-radius:6px;transition:width .4s"></div>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          ${w.tasks.map(t=>`<div style="background:#fff;border:1px solid #fecaca;border-radius:6px;padding:5px 10px;font-size:.75rem">
            <span style="font-weight:600">${escHtml(t.task_name)}</span>
            <span style="color:var(--muted);margin-left:5px">${escHtml(t.sr_rfc)}</span>
            <span style="margin-left:6px;background:#fecaca;color:#b91c1c;padding:1px 7px;border-radius:4px;font-weight:600">${t.tat_mins} mins</span>
          </div>`).join('')}
        </div>
      </div>`;
    }).join('');
  }catch(e){console.error('TAT warnings failed',e);}
}

async function loadCalMonth(){
  const pad=n=>String(n).padStart(2,'0');
  const monthStr=`${calYear}-${pad(calMonth)}`;
  document.getElementById('aCalLabel').textContent=
    new Date(calYear,calMonth-1,1).toLocaleDateString('en-US',{month:'long',year:'numeric'});
  const r=await api(`/api/analytics/daily?month=${monthStr}`);
  const d=await r.json();
  if(!r.ok){console.error('Calendar fetch failed',d);return;}
  calDayData=d.days||{};
  renderCalGrid(d.year,d.month,d.days_in_month,d.first_weekday);
}

function renderCalGrid(year,month,daysInMonth,firstWeekday){
  const pad=n=>String(n).padStart(2,'0');
  const today=new Date();
  const todayStr=`${today.getFullYear()}-${pad(today.getMonth()+1)}-${pad(today.getDate())}`;
  // firstWeekday: 0=Mon…6=Sun → convert to Sun-first grid offset
  const offset=(firstWeekday+1)%7; // Sunday=0 in JS grid
  let html='<div class="cal-grid">';
  ['Su','Mo','Tu','We','Th','Fr','Sa'].forEach(h=>{
    html+=`<div class="cal-hdr">${h}</div>`;
  });
  for(let i=0;i<offset;i++) html+='<div class="cal-day empty"></div>';
  for(let d=1;d<=daysInMonth;d++){
    const dateStr=`${year}-${pad(month)}-${pad(d)}`;
    const info=calDayData[dateStr]||{};
    const total=info.total||0;
    const isToday=dateStr===todayStr;
    const isSel=dateStr===calSelected;
    const hasTasks=total>0;
    let cls='cal-day';
    if(isToday)cls+=' today';
    if(isSel)cls+=' selected';
    if(hasTasks&&!isSel)cls+=' has-tasks';
    // dot colours: created=blue, started=green, due=yellow, blocked=red
    let dots='';
    if(info.created) dots+=`<div class="cal-dot" style="background:#3b82f6" title="${info.created} created"></div>`;
    if(info.started) dots+=`<div class="cal-dot" style="background:#22c55e" title="${info.started} started"></div>`;
    if(info.due)     dots+=`<div class="cal-dot" style="background:#eab308" title="${info.due} due"></div>`;
    if(info.blocked) dots+=`<div class="cal-dot" style="background:#ef4444" title="${info.blocked} blocked"></div>`;
    html+=`<div class="${cls}" data-date="${dateStr}" onclick="selectCalDay('${dateStr}')">
      <div class="cal-dn">${d}</div>
      ${hasTasks?`<div class="cal-dots">${dots}</div><div class="cal-count">${total}</div>`:''}
    </div>`;
  }
  html+='</div>';
  // Legend
  html+=`<div style="display:flex;gap:12px;padding:8px 2px 4px;flex-wrap:wrap">
    ${[['#3b82f6','Created'],['#22c55e','Started'],['#eab308','Due'],['#ef4444','Blocked']].map(([c,l])=>
      `<div style="display:flex;align-items:center;gap:4px;font-size:.68rem;color:var(--muted)">
        <div style="width:7px;height:7px;border-radius:50%;background:${c}"></div>${l}</div>`).join('')}
  </div>`;
  document.getElementById('aCalGrid').innerHTML=html;
}

async function selectCalDay(dateStr){
  if(calSelected===dateStr){
    // Toggle off
    calSelected='';
    renderCalGrid(calYear,calMonth,
      new Date(calYear,calMonth,0).getDate(),
      new Date(calYear,calMonth-1,1).getDay()===0?6:new Date(calYear,calMonth-1,1).getDay()-1);
    document.getElementById('aCalDayDetail')?.remove();
    return;
  }
  calSelected=dateStr;
  // Re-render grid with new selection highlighted
  const daysInMonth=new Date(calYear,calMonth,0).getDate();
  const fw=new Date(calYear,calMonth-1,1).getDay();
  const firstWeekday=fw===0?6:fw-1;
  renderCalGrid(calYear,calMonth,daysInMonth,firstWeekday);
  // Fetch tasks for this day
  const r=await api(`/api/analytics/daily?date=${dateStr}`);
  const d=await r.json();
  renderDayDetail(dateStr,d.tasks||[]);
}

function renderDayDetail(dateStr,tasks){
  const existing=document.getElementById('aCalDayDetail');
  if(existing)existing.remove();
  const date=new Date(dateStr+'T00:00:00');
  const label=date.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
  const statusColor={pending:'#eab308',in_progress:'#3b82f6',review:'#a855f7',done:'#22c55e',blocked:'#ef4444'};
  let rows='';
  if(!tasks.length){
    rows='<div style="color:var(--muted);font-size:.82rem;padding:6px 0">No tasks created, started, or due on this day.</div>';
  } else {
    rows=tasks.map(t=>{
      const flags=(t.day_flags||[]).map(f=>`<span class="day-flag ${f}">${f}</span>`).join(' ');
      const sc=statusColor[t.status]||'#aaa';
      return `<div class="day-task-row">
        <div style="width:4px;border-radius:2px;background:${sc};flex-shrink:0;align-self:stretch;min-height:36px"></div>
        <div style="flex:1;min-width:0">
          <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escHtml(t.task_name||'—')}</div>
          <div style="font-size:.73rem;color:var(--muted);margin-top:2px">
            ${escHtml(t.study_id||'—')} · ${escHtml(t.sr_rfc||'—')} · ${escHtml(t.assignee_name||'Unassigned')}
          </div>
        </div>
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:3px;flex-shrink:0">
          ${flags}
          ${bdg(t.status)}
        </div>
      </div>`;
    }).join('');
  }
  const div=document.createElement('div');
  div.id='aCalDayDetail';
  div.className='day-detail';
  div.style.cssText='margin:0 16px 14px;';
  div.innerHTML=`
    <div class="day-detail-hdr">
      <span>📅 ${escHtml(label)}</span>
      <span style="font-size:.75rem;color:var(--muted);font-weight:400">${tasks.length} task${tasks.length!==1?'s':''}</span>
    </div>
    <div>${rows}</div>`;
  document.getElementById('aCalGrid').after(div);
}

async function shiftCalMonth(delta){
  calMonth+=delta;
  if(calMonth>12){calMonth=1;calYear++;}
  if(calMonth<1){calMonth=12;calYear--;}
  calSelected='';
  document.getElementById('aCalDayDetail')?.remove();
  await loadCalMonth();
}

/* PROCESS MANAGER */
let allProcesses=[];
async function loadProcesses(){
  const r=await api('/api/processes');
  if(!r.ok)return;
  allProcesses=await r.json();
  renderPMChips();
  populateProcDropdowns();
}
function renderPMChips(){
  const c=document.getElementById('pmChips');
  document.getElementById('pmCount').textContent=`${allProcesses.length} mapping process${allProcesses.length!==1?'es':''}`;
  if(!allProcesses.length){c.innerHTML='<span style="color:var(--muted);font-size:.82rem">No mapping processes yet — add one below.</span>';return;}
  const usage={};
  allTN.forEach(d=>{usage[d.process]=(usage[d.process]||0)+1;});
  const activeProc=document.getElementById('tnPF').value;
  // "All" chip
  const allActive=!activeProc?'active':'';
  let html=`<div class="pm-chip ${allActive}" onclick="filterByChip('')" title="Show all">
    <span class="cn">All</span>
    <span class="cc">${allTN.length} task${allTN.length!==1?'s':''}</span>
  </div>`;
  html+=allProcesses.map(p=>{
    const isActive=activeProc===p.name?'active':'';
    return `
    <div class="pm-chip ${isActive}" data-pname="${escHtml(p.name)}" title="Filter by ${escHtml(p.name)}">
      <span class="cn">${escHtml(p.name)}</span>
      <span class="cc">${usage[p.name]||0} task${(usage[p.name]||0)!==1?'s':''}</span>
      <button class="cb ed" data-pid="${p.id}" data-pname="${escHtml(p.name)}" title="Rename">✏️</button>
      <button class="cb dl" data-pid="${p.id}" data-pname="${escHtml(p.name)}" title="Delete">✕</button>
    </div>`;
  }).join('');
  c.innerHTML=html;
  // Attach click handlers after render — avoids apostrophe/backslash issues in inline onclick
  c.querySelectorAll('.pm-chip[data-pname]').forEach(chip=>{
    chip.addEventListener('click',e=>{
      if(e.target.classList.contains('cb'))return; // let button handlers fire separately
      filterByChip(chip.dataset.pname);
    });
  });
  c.querySelectorAll('.cb.ed[data-pid]').forEach(btn=>{
    btn.addEventListener('click',e=>{e.stopPropagation();openEditProc(btn.dataset.pid,btn.dataset.pname);});
  });
  c.querySelectorAll('.cb.dl[data-pid]').forEach(btn=>{
    btn.addEventListener('click',e=>{e.stopPropagation();deleteProc(btn.dataset.pid,btn.dataset.pname);});
  });
}
function filterByChip(procName){
  document.getElementById('tnPF').value=procName;
  document.getElementById('tnSearch').value='';
  document.getElementById('tnSF').value='';
  renderTN();
  renderPMChips(); // refresh active state
  // Only scroll when the Task Names section is actually visible
  const tnSection=document.getElementById('vs-tasknames');
  if(tnSection&&tnSection.classList.contains('active')){
    document.getElementById('tnBody').closest('.panel').scrollIntoView({behavior:'smooth',block:'nearest'});
  }
}
function populateProcDropdowns(){
  const names=allProcesses.map(p=>p.name);
  const pf=document.getElementById('tnPF');
  const pfv=pf.value;
  pf.innerHTML='<option value="">All Mapping Processes</option>'+names.map(n=>`<option${pfv===n?' selected':''}>${n}</option>`).join('');
  const tp=document.getElementById('tnProc');
  const tpv=tp.value;
  tp.innerHTML='<option value="">— Select Mapping Process —</option>'+names.map(n=>`<option${tpv===n?' selected':''}>${n}</option>`).join('');
}
async function addProcess(){
  const inp=document.getElementById('pmNewName');
  const name=inp.value.trim();
  if(!name){toast('Enter a mapping process name','error');return;}
  const r=await api('/api/processes','POST',{name});
  if(r.ok){inp.value='';toast(`Mapping Process "${name}" added`);await loadProcesses();}
  else{const d=await r.json();toast(d.error||'Failed','error');}
}
function openEditProc(id,name){
  document.getElementById('editProcId').value=id;
  document.getElementById('editProcName').value=name;
  openModal('mEditProc');
  setTimeout(()=>document.getElementById('editProcName').focus(),100);
}
async function saveProcessRename(){
  const id=document.getElementById('editProcId').value;
  const name=document.getElementById('editProcName').value.trim();
  if(!name){toast('Name cannot be empty','error');return;}
  const r=await api(`/api/processes/${id}`,'PUT',{name});
  if(r.ok){toast('Mapping Process renamed');closeModal('mEditProc');await loadProcesses();await loadTN();}
  else{const d=await r.json();toast(d.error||'Rename failed','error');}
}
async function deleteProc(id,name){
  const usage=allTN.filter(d=>d.process===name).length;
  if(usage>0){toast(`Cannot delete "${name}" — ${usage} task name(s) use it. Reassign them first.`,'error');return;}
  if(!confirm(`Delete mapping process "${name}"?`))return;
  const r=await api(`/api/processes/${id}`,'DELETE');
  if(r.ok){toast(`"${name}" deleted`);await loadProcesses();}
  else{const d=await r.json();toast(d.error||'Delete failed','error');}
}

/* TASK NAMES */
async function loadTN(){const r=await api('/api/task-names');allTN=await r.json();renderTN();renderPMChips();}
function renderTN(){
  const s=document.getElementById('tnSearch').value.toLowerCase();
  const p=document.getElementById('tnPF').value;
  const st=document.getElementById('tnSF').value;
  const f=allTN.filter(d=>(!s||d.task_name.toLowerCase().includes(s)||d.process.toLowerCase().includes(s))&&(!p||d.process===p)&&(!st||d.status===st));
  document.getElementById('tnCount').textContent=`${f.length} of ${allTN.length}`;
  const tbody=document.getElementById('tnBody');
  if(!f.length){tbody.innerHTML='<tr><td colspan="7"><div class="empty"><div class="ei">🏷️</div>No task names found</div></td></tr>';return;}
  tbody.innerHTML=f.map((d,i)=>{
    const cls=d.cap_timing<=30?'ok':d.cap_timing<=60?'warn':'danger';
    return `<tr>
      <td style="color:var(--muted);font-size:.75rem">${i+1}</td>
      <td><span class="pchip">${escHtml(d.process)}</span></td>
      <td style="font-weight:500">${escHtml(d.task_name)}</td>
      <td><span class="cap-pill ${cls}">&#9200; ${d.cap_timing} mins</span></td>
      <td>${bdg(d.status)}</td>
      <td style="font-size:.77rem;color:var(--muted)">${escHtml(d.created_at)||'—'}</td>
      <td style="white-space:nowrap">
        <button class="btn btn-outline btn-sm" onclick="editTN(${d.id})">✏️ Edit</button>
        <button class="btn btn-danger btn-sm" onclick="delTN(${d.id})">🗑 Delete</button>
      </td></tr>`;}).join('');
}
function openNewTN(){
  document.getElementById('eTNId').value='';document.getElementById('mTNTitle').textContent='Add Task Name';
  document.getElementById('tnProc').value='';document.getElementById('tnName').value='';
  document.getElementById('tnCap').value='';document.getElementById('tnStat').value='active';
  openModal('mTN');
}
function editTN(id){
  const d=allTN.find(x=>x.id===id);if(!d)return;
  document.getElementById('eTNId').value=id;document.getElementById('mTNTitle').textContent='Edit Task Name';
  document.getElementById('tnProc').value=d.process;document.getElementById('tnName').value=d.task_name;
  document.getElementById('tnCap').value=d.cap_timing;document.getElementById('tnStat').value=d.status;
  openModal('mTN');
}
async function saveTN(){
  const eid=document.getElementById('eTNId').value;
  const body={process:document.getElementById('tnProc').value,task_name:document.getElementById('tnName').value.trim(),
    cap_timing:parseInt(document.getElementById('tnCap').value),status:document.getElementById('tnStat').value};
  if(!body.process||!body.task_name||!body.cap_timing){toast('All fields required','error');return;}
  const r=await api(eid?`/api/task-names/${eid}`:'/api/task-names',eid?'PUT':'POST',body);
  if(r.ok){toast(eid?'Updated':'Added');closeModal('mTN');loadTN();}
  else{const d=await r.json();toast(d.error||'Failed','error');}
}
async function delTN(id){
  if(!confirm('Delete this task name?'))return;
  const r=await api(`/api/task-names/${id}`,'DELETE');
  if(r.ok){toast('Deleted');loadTN();}else toast('Failed','error');
}

/* IMPORT */
function iDrop(e){e.preventDefault();document.getElementById('iZone').classList.remove('drag');const f=e.dataTransfer.files[0];if(f)iHandle(f);}
async function iHandle(file){
  if(!file||!file.name.toLowerCase().endsWith('.xlsx')){toast('Upload a .xlsx file','error');return;}
  const zone=document.getElementById('iZone');
  if(zone)zone.innerHTML='<div style="font-size:2rem">⏳</div><div>Parsing file…</div>';
  try{
    const fd=new FormData();fd.append('file',file);
    const r=await fetch('/api/task-names/parse-xlsx',{method:'POST',headers:{'X-CSRF-Token':document.querySelector('meta[name="csrf-token"]')?.content||''},body:fd});
    const d=await r.json();
    if(!r.ok){toast(d.error||'Failed to parse file','error');resetImp();return;}
    iParseRows(d.rows);
  }catch(err){toast('Upload error: '+err.message,'error');resetImp();}
}
function stripApex(s){return typeof s==='string'?s.replace(/^'+/,'').trim():s;}function nkey(obj,...keys){const lk=Object.keys(obj).reduce((a,k)=>{a[k.replace(/^'+/,'').toLowerCase().trim()]=k;return a;},{});for(const k of keys){const m=lk[k.toLowerCase()];if(m!==undefined)return stripApex(obj[m]);}return '';}
function iParseRows(data){
  // data comes pre-parsed from server
  impRows=data;
  const v=impRows.filter(r=>r.valid).length,iv=impRows.length-v;
  document.getElementById('iStep1').style.display='none';
  document.getElementById('iStep2').style.display='block';
  document.getElementById('iLabel').textContent=`Preview: ${impRows.length} rows`;
  document.getElementById('iVC').textContent=`${v} valid, ${iv} invalid`;
  const res=document.getElementById('iResult');
  if(iv===0){res.className='imp-result success';res.textContent=`All ${v} rows valid.`;}
  else if(v===0){res.className='imp-result error';res.textContent='No valid rows found.';}
  else{res.className='imp-result partial';res.textContent=`${v} valid rows will import, ${iv} skipped.`;}
  res.style.display='block';
  document.getElementById('iPrev').innerHTML=impRows.map(r=>`
    <tr style="${r.valid?'':'background:#fff8f7'}">
      <td style="color:var(--muted);font-size:.75rem">${r.idx}</td>
      <td>${r.process||'<span style="color:var(--red)">—</span>'}</td>
      <td>${r.task_name||'<span style="color:var(--red)">—</span>'}</td>
      <td>${isNaN(r.cap_timing)?'<span style="color:var(--red)">—</span>':r.cap_timing+' mins'}</td>
      <td>${r.valid?'<span style="color:var(--green);font-weight:600">✓</span>':`<span style="color:var(--red);font-size:.75rem">✗ ${r.errors.join(', ')}</span>`}</td>
    </tr>`).join('');
}
async function doImport(){
  const valid=impRows.filter(r=>r.valid);if(!valid.length){toast('No valid rows','error');return;}
  const btn=document.getElementById('iCBtn');
  btn.disabled=true;btn.textContent='Importing…';
  const r=await api('/api/task-names/bulk','POST',{rows:valid});
  if(r.ok){const d=await r.json();toast(`Imported ${d.imported} task names`);closeModal('mImport');resetImp();loadTN();}
  else{const d=await r.json();toast(d.error||'Failed','error');btn.disabled=false;btn.textContent='✓ Import';}
}
function resetImp(){
  document.getElementById('iStep1').style.display='block';
  document.getElementById('iStep2').style.display='none';
  document.getElementById('iFile').value='';
  document.getElementById('iResult').style.display='none';
  document.getElementById('iCBtn').textContent='✓ Import';
  impRows=[];
  const z=document.getElementById('iZone');
  if(z)z.innerHTML='<div class="zone-icon">📂</div><div class="zone-title">Click or drag &amp; drop .xlsx</div>';
}
let _mdTarget = null;
document.addEventListener('mousedown', e => { _mdTarget = e.target; });
document.querySelectorAll('.overlay').forEach(ov => {
  ov.addEventListener('click', e => {
    if (e.target === ov && _mdTarget === ov) {
      ov.classList.remove('open');
      if (ov.id === 'mImport') resetImp();
    }
  });
});

// Inject CSRF token from server into sessionStorage so all API calls work
// CSRF token is read from <meta name='csrf-token'> — no sessionStorage needed
// BUG-FIX: wrap init in async try/catch so a loadDash() failure
// does not prevent sidebar nav click handlers from responding
/* Live clock */
(function(){
  function tick(){
    const now=new Date();
    const h=now.getHours(),m=now.getMinutes(),s=now.getSeconds();
    const ampm=h>=12?'PM':'AM',h12=h%12||12;
    const pad=n=>String(n).padStart(2,'0');
    const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const te=document.getElementById('tcTime');
    const de=document.getElementById('tcDate');
    if(te)te.textContent=`${pad(h12)}:${pad(m)}:${pad(s)} ${ampm}`;
    if(de)de.textContent=`${days[now.getDay()]}, ${months[now.getMonth()]} ${now.getDate()}, ${now.getFullYear()}`;
  }
  tick();setInterval(tick,1000);
})();
(async()=>{try{await loadDash();}catch(e){console.error('init loadDash:',e);}})();
</script>

<!-- EDIT TASK MODAL (All Tasks page) -->
<div class="overlay" id="mEditTask">
  <div class="modal modal-lg">
    <div class="mh">
      <span class="mt">✏️ Edit Task</span>
      <button class="mc" onclick="closeModal('mEditTask')">&#215;</button>
    </div>
    <div class="mb">
      <input type="hidden" id="etId">
      <div class="fr">
        <div class="fg">
          <label>Study ID</label>
          <input type="text" id="etStudyId" readonly
                 style="background:#f9f8f5;color:#888;cursor:not-allowed">
        </div>
        <div class="fg">
          <label>SR / RFC</label>
          <input type="text" id="etSrRfc" placeholder="e.g. RFC-2024-1001" maxlength="100">
        </div>
      </div>
      <div class="fr">
        <div class="fg">
          <label>Mapping Process</label>
          <input type="text" id="etProcess" readonly
                 style="background:#f9f8f5;color:#888;cursor:not-allowed">
        </div>
        <div class="fg">
          <label>Task Name</label>
          <input type="text" id="etTaskName" readonly
                 style="background:#f9f8f5;color:#888;cursor:not-allowed">
        </div>
      </div>
      <div class="fg">
        <label>Sub Task <span style="font-size:.67rem;font-weight:400;text-transform:none;color:var(--muted)">(letters &amp; numbers only)</span></label>
        <input type="text" id="etSubtask" placeholder="Optional subtask detail…" maxlength="200"
               oninput="this.value=this.value.replace(/[^a-zA-Z0-9 ]/g,'')"
               onpaste="setTimeout(()=>this.value=this.value.replace(/[^a-zA-Z0-9 ]/g,''),0)">
      </div>
      <div class="fr">
        <div class="fg">
          <label>Assigned To *</label>
          <select id="etAssignee"></select>
        </div>
        <div class="fg">
          <label>Priority</label>
          <select id="etPri">
            <option value="low">Low</option>
            <option value="medium">Medium</option>
            <option value="high">High</option>
            <option value="critical">Critical</option>
          </select>
        </div>
      </div>
      <div class="fr">
        <div class="fg">
          <label>Turnaround Time (mins) *</label>
          <input type="number" id="etTAT" min="1" max="99999" placeholder="e.g. 60">
        </div>
        <div class="fg">
          <label>Volume</label>
          <input type="number" id="etVol" min="1" max="9999" value="1">
        </div>
      </div>
      <div class="fr">
        <div class="fg">
          <label>Start Date</label>
          <input type="date" id="etStarted">
        </div>
        <div class="fg">
          <label>Due Date *</label>
          <input type="date" id="etDue">
        </div>
      </div>
      <div class="fg">
        <label>Status</label>
        <select id="etStat">
          <option value="pending">Pending</option>
          <option value="in_progress">In Progress</option>
          <option value="review">Review</option>
          <option value="done">Done</option>
          <option value="blocked">Blocked</option>
        </select>
      </div>
      <div class="fg">
        <label>Notes</label>
        <textarea id="etNotes" placeholder="Additional context…"></textarea>
      </div>
      <div class="ma">
        <button class="btn btn-outline" onclick="closeModal('mEditTask')">Cancel</button>
        <button class="btn btn-gold"    onclick="atSaveEdit()">Save Changes</button>
      </div>
    </div>
  </div>
</div>

<!-- DELETE CONFIRM MODAL (All Tasks page) -->
<div class="overlay" id="mDelTask">
  <div class="modal" style="max-width:420px;">
    <div class="mh"><span class="mt" style="color:var(--red)">🗑 Delete Task</span><button class="mc" onclick="closeModal('mDelTask')">&#215;</button></div>
    <div class="mb">
      <p style="font-size:.9rem;color:#444;margin-bottom:18px;line-height:1.55;">
        Are you sure you want to delete this task?<br>
        <span id="delTaskDesc" style="font-weight:600;color:var(--ink)"></span><br>
        <span style="font-size:.8rem;color:var(--muted)">This action cannot be undone.</span>
      </p>
      <input type="hidden" id="delTaskId">
      <div class="ma">
        <button class="btn btn-outline" onclick="closeModal('mDelTask')">Cancel</button>
        <button class="btn btn-danger"  onclick="atConfirmDelete()">Yes, Delete</button>
      </div>
    </div>
  </div>
</div>


</body>
</html>