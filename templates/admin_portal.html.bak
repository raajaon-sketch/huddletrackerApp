          <div class="ph" style="flex-wrap:wrap;gap:8px">
            <span class="pt">Key Metrics</span>
            <div style="display:flex;align-items:center;gap:6px;margin-left:auto">
              <button class="btn btn-outline btn-sm" id="aCalPrev" onclick="shiftCalMonth(-1)">&#8249;</button>
              <span id="aCalLabel" style="font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;min-width:110px;text-align:center">—</span>
              <button class="btn btn-outline btn-sm" id="aCalNext" onclick="shiftCalMonth(1)">&#8250;</button>
            </div>
