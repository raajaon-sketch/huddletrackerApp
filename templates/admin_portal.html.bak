      </div>
    </div>

    <!-- TASK NAMES -->
    <div class="vs" id="vs-tasknames">
      <!-- ── Mapping Process Manager ── -->
      <div class="panel" style="margin-bottom:16px">
        <div class="ph" style="flex-wrap:wrap;gap:8px">
          <span class="pt">⚙️ Mapping Process Manager</span>
          <span id="pmCount" style="font-size:.75rem;color:var(--muted);align-self:center"></span>
        </div>
        <div id="pmChips" style="padding:12px 16px;display:flex;flex-wrap:wrap;gap:8px;min-height:52px;align-items:center">
          <span style="color:var(--muted);font-size:.82rem">Loading…</span>
        </div>
        <div style="display:flex;gap:8px;padding:0 16px 14px;align-items:center">
          <input type="text" id="pmNewName" placeholder="New mapping process name…" maxlength="200"
                 style="flex:1;padding:7px 12px;border:1.5px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.85rem;outline:none"
                 onkeydown="if(event.key==='Enter')addProcess()">
          <button class="btn btn-primary btn-sm" onclick="addProcess()">+ Add Mapping Process</button>
        </div>
      </div>

      <div class="fbar">
        <input type="text" id="tnSearch" placeholder="&#128269; Search task or mapping process…" oninput="renderTN()">
        <select id="tnPF" onchange="renderTN()">
          <option value="">All Mapping Processes</option>
        </select>
        <select id="tnSF" onchange="renderTN()">
          <option value="">All Status</option>
          <option value="active">Active</option>
          <option value="inactive">Inactive</option>
        </select>
      </div>
      <div class="panel">
        <div class="ph">
          <span class="pt">Task Names Master List</span>
          <span id="tnCount" style="font-size:.78rem;color:var(--muted)"></span>
        </div>
        <div class="tbl-wrap">
          <table>
            <thead><tr><th>#</th><th>Mapping Process</th><th>Task Name</th><th>Cap Timing</th><th>Status</th><th>Created</th><th>Actions</th></tr></thead>
            <tbody id="tnBody"></tbody>
          </table>
        </div>
      </div>
    </div>

  </div>
</div>

