<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="csrf-token" content="{{ csrf_token() }}">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Portal – Huddle</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--ink:#0a0a0f;--paper:#f4f1eb;--accent:#ff4d2e;--green:#22c55e;--yellow:#eab308;--blue:#3b82f6;--purple:#a855f7;--red:#ef4444;--gold:#c9a84c;--card:#fff;--border:#e5e3dc;--muted:#888;--sw:248px;}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--ink);min-height:100vh;display:flex;}
.sidebar{width:var(--sw);background:var(--ink);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;overflow:hidden;}
.sb-brand{padding:22px 20px 16px;border-bottom:1px solid rgba(255,255,255,.07);}
.sb-logo{font-family:'Syne',sans-serif;font-size:1.45rem;font-weight:800;color:#fff;letter-spacing:-1px;}
.sb-logo em{color:var(--accent);font-style:normal;}
.sb-sub{font-size:.6rem;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.25);margin-top:5px;}
.sb-user{padding:13px 20px;border-bottom:1px solid rgba(255,255,255,.07);display:flex;align-items:center;gap:10px;}
.sb-avatar{width:32px;height:32px;border-radius:9px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:.8rem;color:#fff;flex-shrink:0;}
.sb-uname{font-size:.85rem;font-weight:500;color:#fff;}
.sb-role{font-size:.68rem;color:rgba(255,255,255,.32);text-transform:capitalize;}
.sb-nav{padding:10px 10px;flex:1;overflow-y:auto;}
.nav-lbl{font-size:.58rem;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.22);padding:12px 10px 5px;}
.ni{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:8px;cursor:pointer;color:rgba(255,255,255,.52);font-size:.875rem;transition:all .15s;margin-bottom:1px;text-decoration:none;}
.ni:hover,.ni.active{background:rgba(255,255,255,.07);color:#fff;}
.ni.active{color:var(--accent);}
.ni-icon{width:20px;text-align:center;}
.sb-foot{padding:14px 20px;border-top:1px solid rgba(255,255,255,.07);display:flex;flex-direction:column;gap:8px;flex-shrink:0;}
.sw-btn{display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:8px;background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.22);color:var(--gold);font-size:.8rem;cursor:pointer;text-decoration:none;transition:all .15s;}
.sw-btn:hover{background:rgba(201,168,76,.18);}
.lo-btn{display:flex;align-items:center;justify-content:center;gap:8px;padding:9px 12px;border-radius:8px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.22);color:#f87171;font-size:.8rem;font-weight:500;text-decoration:none;cursor:pointer;transition:all .15s;}
.lo-btn:hover{background:rgba(239,68,68,.22);color:#fff;border-color:rgba(239,68,68,.5);}
.main{margin-left:var(--sw);flex:1;display:flex;flex-direction:column;min-height:100vh;}
.topbar{background:var(--card);border-bottom:1px solid var(--border);padding:13px 26px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.page-title{font-family:'Syne',sans-serif;font-size:1.15rem;font-weight:700;}
.tb-right{display:flex;gap:8px;align-items:center;}
.tb-clock{display:flex;flex-direction:column;align-items:flex-end;line-height:1.25;margin-right:4px;}
.tb-clock .tc-time{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;letter-spacing:.5px;color:var(--ink);}
.tb-clock .tc-date{font-size:.68rem;color:var(--muted);letter-spacing:.3px;}
.btn{padding:7px 15px;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:500;cursor:pointer;border:none;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--ink);color:#fff;}.btn-primary:hover{background:var(--accent);}
.btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--ink);}.btn-outline:hover{border-color:var(--ink);}
.btn-danger{background:var(--red);color:#fff;}.btn-danger:hover{opacity:.85;}
.btn-success{background:var(--green);color:#fff;}
.btn-purple{background:var(--purple);color:#fff;}
.btn-gold{background:var(--gold);color:#0a0a0f;}.btn-gold:hover{opacity:.88;}
.btn-sm{padding:5px 11px;font-size:.78rem;}
.content{padding:26px;}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(165px,1fr));gap:13px;margin-bottom:22px;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:17px 20px;position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--c,var(--accent));}
.stat-value{font-family:'Syne',sans-serif;font-size:1.85rem;font-weight:800;line-height:1;margin-bottom:4px;}
.stat-label{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px;}
.panels{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px;}
@media(max-width:1080px){.panels{grid-template-columns:1fr}}
.panel{background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:18px;}
.ph{padding:15px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.pt{font-family:'Syne',sans-serif;font-weight:700;font-size:.92rem;}
.tbl-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:.83rem;}
thead th{background:#f9f8f5;padding:10px 15px;text-align:left;font-size:.67rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);font-weight:500;border-bottom:1px solid var(--border);white-space:nowrap;}
tbody td{padding:11px 15px;border-bottom:1px solid var(--border);vertical-align:middle;}
tbody tr:last-child td{border-bottom:none;}
tbody tr:hover{background:#fafaf8;}
.mono{font-family:monospace;font-size:.77rem;color:#555;}
.badge{display:inline-block;padding:2px 9px;border-radius:20px;font-size:.68rem;font-weight:500;text-transform:capitalize;}
.badge-pending{background:#fef9c3;color:#854d0e;}
.badge-in_progress{background:#dbeafe;color:#1e40af;}
.badge-review{background:#f3e8ff;color:#6b21a8;}
.badge-done{background:#dcfce7;color:#14532d;}
.badge-blocked{background:#fee2e2;color:#991b1b;}
.badge-low{background:#f1f5f9;color:#475569;}
.badge-medium{background:#fef9c3;color:#854d0e;}
.badge-high{background:#fed7aa;color:#9a3412;}
.badge-critical{background:#fee2e2;color:#991b1b;}
.badge-active{background:#dcfce7;color:#14532d;}
.badge-completed{background:#dbeafe;color:#1e40af;}
.badge-archived{background:#f1f5f9;color:#475569;}
.badge-admin{background:#fee2e2;color:#991b1b;}
.badge-lead{background:#fed7aa;color:#9a3412;}
.badge-member{background:#dbeafe;color:#1e40af;}
.badge-inactive{background:#f1f5f9;color:#475569;}
.pchip{display:inline-block;padding:2px 9px;border-radius:6px;font-size:.7rem;font-weight:600;background:var(--ink);color:#fff;}
.cap-pill{display:inline-flex;align-items:center;gap:3px;border-radius:20px;padding:2px 9px;font-size:.73rem;font-weight:500;}
.cap-pill.ok{background:#f0f9ff;color:#0369a1;border:1px solid #bae6fd;}
.cap-pill.warn{background:#fefce8;color:#854d0e;border:1px solid #fde68a;}
.cap-pill.danger{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;}
.pm-chip{display:inline-flex;align-items:center;gap:5px;background:#f5f3ee;border:1.5px solid var(--border);border-radius:8px;padding:5px 9px;font-size:.8rem;font-weight:500;transition:all .15s;cursor:pointer;}
.pm-chip:hover{border-color:#aaa;}
.pm-chip.active{background:var(--ink);color:#fff;border-color:var(--ink);}
.pm-chip.active .cc{background:rgba(255,255,255,.2);color:rgba(255,255,255,.8);}
.pm-chip.active .cb.ed{color:rgba(255,255,255,.6);}.pm-chip.active .cb.ed:hover{background:rgba(255,255,255,.15);color:#fff;}
.pm-chip.active .cb.dl{color:rgba(255,255,255,.4);}.pm-chip.active .cb.dl:hover{background:rgba(239,68,68,.4);color:#fff;}
.pm-chip .cn{max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.pm-chip .cc{font-size:.66rem;background:var(--border);border-radius:20px;padding:1px 5px;color:var(--muted);}
.pm-chip .cb{border:none;background:none;cursor:pointer;padding:1px 3px;border-radius:3px;font-size:.75rem;line-height:1;transition:background .12s;}
.pm-chip .cb.ed{color:#777;}.pm-chip .cb.ed:hover{background:#e8e6e0;color:var(--ink);}
.pm-chip .cb.dl{color:#ccc;}.pm-chip .cb.dl:hover{background:#fee2e2;color:var(--red);}
.fbar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
.fbar input,.fbar select{padding:8px 12px;border:1.5px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.83rem;background:var(--card);outline:none;transition:border-color .15s;}
.fbar input:focus,.fbar select:focus{border-color:var(--ink);}
.fbar input{flex:1;min-width:180px;}
.overlay{position:fixed;inset:0;background:rgba(10,10,15,.65);backdrop-filter:blur(4px);z-index:200;display:none;align-items:center;justify-content:center;}
.overlay.open{display:flex;}
.modal{background:var(--card);border-radius:16px;width:520px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 24px 70px rgba(0,0,0,.3);}
.modal-lg{width:640px;}
.mh{padding:20px 24px 0;display:flex;align-items:center;justify-content:space-between;}
.mt{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:700;}
.mc{background:none;border:none;font-size:1.35rem;cursor:pointer;color:var(--muted);line-height:1;}
.mb{padding:16px 24px 24px;}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:11px;}
.fg{margin-bottom:13px;}
.fg label{display:block;font-size:.72rem;font-weight:500;text-transform:uppercase;letter-spacing:.8px;margin-bottom:5px;}
.fg input,.fg select,.fg textarea{width:100%;padding:9px 13px;border:1.5px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:.875rem;outline:none;transition:border-color .15s;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--accent);}
.fg textarea{resize:vertical;min-height:68px;}
.ma{display:flex;gap:8px;justify-content:flex-end;margin-top:6px;}
.pb{background:#f0ede8;border-radius:4px;height:6px;overflow:hidden;}
.pf{height:100%;background:var(--accent);border-radius:4px;transition:width .4s;}
.donut-wrap{display:flex;align-items:center;gap:20px;padding:16px 20px;}
.donut{position:relative;width:88px;height:88px;flex-shrink:0;}
.donut svg{transform:rotate(-90deg);}
.dc{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:1.15rem;}
.legend{flex:1;display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.legend-item{display:flex;align-items:center;gap:7px;font-size:.77rem;}
.ldot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}

.urow{display:flex;align-items:center;gap:13px;padding:14px 18px;border-bottom:1px solid var(--border);}
.urow:last-child{border-bottom:none;}
.urow:hover{background:rgba(255,255,255,.025);}
.uav{width:36px;height:36px;border-radius:9px;background:var(--ink);color:#fff;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:.78rem;flex-shrink:0;}
.u-info{flex:1;min-width:0;}
.u-name{font-weight:600;font-size:.88rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.u-meta{font-size:.73rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.u-activity{display:flex;gap:6px;align-items:center;flex-shrink:0;}
.u-day{display:flex;flex-direction:column;align-items:center;gap:2px;min-width:52px;}
.u-day-lbl{font-size:.6rem;color:var(--muted);text-transform:uppercase;letter-spacing:.4px;white-space:nowrap;}
.u-day-pill{font-size:.72rem;font-weight:700;padding:3px 10px;border-radius:20px;min-width:32px;text-align:center;}
.u-day-pill.has-tasks{background:rgba(34,197,94,.15);color:#22c55e;border:1px solid rgba(34,197,94,.3);}
.u-day-pill.no-tasks{background:rgba(255,255,255,.05);color:var(--muted);border:1px solid var(--border);}
.u-day-pill.today-has{background:rgba(201,168,76,.15);color:var(--gold);border:1px solid rgba(201,168,76,.3);}
.users-scroll{max-height:calc(100vh - 180px);overflow-y:auto;}
.users-scroll::-webkit-scrollbar{width:5px;}
.users-scroll::-webkit-scrollbar-track{background:transparent;}
.users-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
.users-scroll::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,.2);}
.u-divider{display:flex;align-items:center;gap:10px;padding:6px 18px 4px;font-size:.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;border-bottom:1px solid var(--border);background:rgba(255,255,255,.02);}
.u-section-title{font-size:.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:.6px;}
.imp-zone{border:2px dashed var(--border);border-radius:10px;padding:30px;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:12px;}
.imp-zone:hover,.imp-zone.drag{border-color:var(--accent);background:#fff8f7;}
.imp-result{padding:10px 13px;border-radius:8px;font-size:.83rem;margin-bottom:10px;display:none;}
.imp-result.success{background:#dcfce7;color:#14532d;border:1px solid #86efac;}
.imp-result.error{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;}
.imp-result.partial{background:#fef9c3;color:#854d0e;border:1px solid #fde68a;}
.prev-wrap{max-height:210px;overflow-y:auto;border:1px solid var(--border);border-radius:8px;margin-bottom:11px;}
.toast{position:fixed;bottom:20px;right:20px;background:var(--ink);color:#fff;padding:10px 18px;border-radius:10px;font-size:.875rem;z-index:999;transform:translateY(80px);opacity:0;transition:all .3s;}
.toast.show{transform:translateY(0);opacity:1;}
.vs{display:none;}.vs.active{display:block;}
.empty{text-align:center;padding:46px 20px;color:var(--muted);}
.ei{font-size:2.2rem;margin-bottom:8px;opacity:.38;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px;}
.cal-hdr{font-size:.6rem;text-transform:uppercase;letter-spacing:1px;color:var(--muted);text-align:center;padding:4px 0;font-weight:600;}
.cal-day{border-radius:8px;padding:5px 4px 4px;min-height:52px;cursor:pointer;transition:all .15s;position:relative;border:1.5px solid transparent;background:#f9f8f5;}
.cal-day:hover{border-color:var(--ink);background:#fff;}
.cal-day.empty{background:transparent;cursor:default;border:none;}
.cal-day.today{border-color:var(--accent)!important;background:#fff8f7;}
.cal-day.selected{border-color:var(--ink)!important;background:var(--ink);}
.cal-day.selected .cal-dn{color:#fff;}
.cal-day.selected .cal-dot{opacity:.85;}
.cal-day.has-tasks{background:#fff;}
.cal-dn{font-family:'Syne',sans-serif;font-weight:700;font-size:.75rem;line-height:1;margin-bottom:4px;color:var(--ink);}
.cal-dots{display:flex;flex-wrap:wrap;gap:2px;margin-top:2px;}
.cal-dot{width:6px;height:6px;border-radius:50%;}
.cal-count{font-size:.6rem;color:var(--muted);font-weight:600;margin-top:2px;}
.day-detail{background:#f9f8f5;border-radius:10px;padding:12px 14px;margin-bottom:12px;border:1.5px solid var(--border);}
.day-detail-hdr{font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;}
.day-task-row{display:flex;align-items:flex-start;gap:8px;padding:7px 0;border-bottom:1px solid var(--border);font-size:.8rem;}
.day-task-row:last-child{border-bottom:none;}
.day-flag{display:inline-block;padding:1px 6px;border-radius:4px;font-size:.62rem;font-weight:600;text-transform:uppercase;letter-spacing:.5px;}
.day-flag.created{background:#dbeafe;color:#1e40af;}
.day-flag.started{background:#dcfce7;color:#14532d;}
.day-flag.due{background:#fef9c3;color:#854d0e;}

::-webkit-scrollbar-thumb{background:#d0cdc7;border-radius:3px;}
</style>
</head>
<body>

<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-logo">Huddle<em>.</em></div>
    <div class="sb-sub">Admin Portal</div>
  </div>
  <div class="sb-user">
    <div class="sb-avatar">{{ user.username[0].upper() }}</div>
    <div>
      <div class="sb-uname">{{ user.username }}</div>
      <div class="sb-role">{{ user.role }}</div>
    </div>
  </div>
  <nav class="sb-nav">
    <div class="nav-lbl">Management</div>
    <div class="ni active" data-view="dashboard" onclick="show('dashboard')"><span class="ni-icon">📊</span>Dashboard</div>
    <div class="ni" data-view="users" onclick="show('users')"><span class="ni-icon">👥</span>Users</div>
    <div class="ni" data-view="analytics" onclick="show('analytics')"><span class="ni-icon">📈</span>Analytics</div>
    <div class="nav-lbl">Configuration</div>
    <div class="ni" data-view="tasks" onclick="show('tasks')"><span class="ni-icon">📋</span>All Tasks</div>
    <div class="ni" data-view="tasknames" onclick="show('tasknames')"><span class="ni-icon">🏷️</span>Task Names</div>
  </nav>
  <div class="sb-foot">
    <a class="sw-btn" href="/huddle">🎯 Switch to Huddle Portal</a>
    <a class="lo-btn" href="/logout">⏻ Sign Out</a>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <div class="page-title" id="pgTitle">Dashboard</div>
    <div class="tb-clock" id="tbClock">
      <span class="tc-time" id="tcTime">--:-- --</span>
      <span class="tc-date" id="tcDate">--- --, ----</span>
    </div>
    <div class="tb-right">
      <button class="btn btn-outline btn-sm" id="bTaskExport" onclick="exportAllTasksPage()" style="display:none">⬇ Export</button>
      <button class="btn btn-primary btn-sm" id="bNewUser" onclick="openNewUser()" style="display:none">+ User</button>
      <button class="btn btn-purple btn-sm" id="bImpTN" onclick="openModal('mImport')" style="display:none">📤 Import</button>
      <button class="btn btn-primary btn-sm" id="bAddTN" onclick="openNewTN()" style="display:none">+ Task Name</button>
    </div>
  </div>

  <div class="content">

    <!-- DASHBOARD -->
    <div class="vs active" id="vs-dashboard">
      <div class="stats-grid" id="dStats"></div>
      <div class="panels">
        <div class="panel">
          <div class="ph"><span class="pt">Task Status</span></div>
          <div class="donut-wrap">
            <div class="donut">
              <svg width="88" height="88" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="40" fill="none" stroke="#f0ede8" stroke-width="14"/>
                <circle id="cDone"  cx="50" cy="50" r="40" fill="none" stroke="#22c55e" stroke-width="14" stroke-dasharray="0 251" stroke-linecap="round"/>
                <circle id="cPend"  cx="50" cy="50" r="40" fill="none" stroke="#eab308" stroke-width="14" stroke-dasharray="0 251" stroke-linecap="round"/>
                <circle id="cInpro" cx="50" cy="50" r="40" fill="none" stroke="#3b82f6" stroke-width="14" stroke-dasharray="0 251" stroke-linecap="round"/>
              </svg>
              <div class="dc" id="dPct">0%</div>
            </div>
            <div class="legend">
              <div class="legend-item"><div class="ldot" style="background:#22c55e"></div>Done</div>
              <div class="legend-item"><div class="ldot" style="background:#eab308"></div>Pending</div>
              <div class="legend-item"><div class="ldot" style="background:#3b82f6"></div>In Progress</div>
              <div class="legend-item"><div class="ldot" style="background:#ef4444"></div>Blocked</div>
            </div>
          </div>
        </div>
        <div class="panel">
          <div class="ph"><span class="pt">Priority Breakdown</span></div>
          <div id="dPriority" style="padding:18px 20px"></div>
        </div>
      </div>
    </div>

    <!-- ALL TASKS PAGE -->
    <div class="vs" id="vs-tasks">
      <div class="panel" style="margin-bottom:0">
        <div class="ph" style="flex-wrap:wrap;gap:10px;padding:14px 18px;">
          <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
            <span class="pt">All Tasks</span>
            <span id="atCount" style="font-size:.75rem;color:var(--muted);background:#f0ede8;padding:2px 9px;border-radius:20px;font-weight:500;"></span>
          </div>
          <div style="display:flex;gap:7px;align-items:center;flex-wrap:wrap;">
            <button class="btn btn-outline btn-sm" onclick="atClearFilters()">✕ Clear</button>
          </div>
        </div>

        <!-- Filter bar -->
        <div style="padding:10px 18px 12px;border-bottom:1px solid var(--border);display:flex;flex-wrap:wrap;gap:8px;background:#fafaf8;">
          <input  id="atf_study"    type="text"  placeholder="Study ID…"           oninput="renderAT()"
                  style="width:115px;padding:7px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:.78rem;outline:none;font-family:'DM Sans',sans-serif;background:#fff;">
          <input  id="atf_srrfc"   type="text"  placeholder="SR/RFC…"              oninput="renderAT()"
                  style="width:105px;padding:7px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:.78rem;outline:none;font-family:'DM Sans',sans-serif;background:#fff;">
          <input  id="atf_task"    type="text"  placeholder="Task name…"           oninput="renderAT()"
                  style="width:130px;padding:7px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:.78rem;outline:none;font-family:'DM Sans',sans-serif;background:#fff;">
          <select id="atf_process" onchange="renderAT()"
                  style="padding:7px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:.78rem;outline:none;font-family:'DM Sans',sans-serif;background:#fff;">
            <option value="">All Mapping Processes</option>
          </select>
          <input  id="atf_assignee" type="text" placeholder="Assignee…"           oninput="renderAT()"
                  style="width:110px;padding:7px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:.78rem;outline:none;font-family:'DM Sans',sans-serif;background:#fff;">
          <input  id="atf_entid"   type="text"  placeholder="Ent. ID…"             oninput="renderAT()"
                  style="width:100px;padding:7px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:.78rem;outline:none;font-family:'DM Sans',sans-serif;background:#fff;">
          <select id="atf_status"  onchange="renderAT()"
                  style="padding:7px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:.78rem;outline:none;font-family:'DM Sans',sans-serif;background:#fff;">
            <option value="">All Status</option>
            <option value="pending">Pending</option>
            <option value="in_progress">In Progress</option>
            <option value="review">Review</option>
            <option value="done">Done</option>
            <option value="blocked">Blocked</option>
          </select>
          <select id="atf_priority" onchange="renderAT()"
                  style="padding:7px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:.78rem;outline:none;font-family:'DM Sans',sans-serif;background:#fff;">
            <option value="">All Priority</option>
            <option value="critical">Critical</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
          <input  id="atf_due"     type="date"  onchange="renderAT()"
                  title="Filter by Due Date"
                  style="padding:7px 10px;border:1.5px solid var(--border);border-radius:7px;font-size:.78rem;outline:none;font-family:'DM Sans',sans-serif;background:#fff;">
        </div>

        <!-- Table -->
        <div class="tbl-wrap">
          <table>
            <thead><tr>
              <th onclick="atSort('study_id')"       style="cursor:pointer;user-select:none">Study ID <span id="ats_study_id"></span></th>
              <th onclick="atSort('sr_rfc')"         style="cursor:pointer;user-select:none">SR/RFC <span id="ats_sr_rfc"></span></th>
              <th onclick="atSort('process')"        style="cursor:pointer;user-select:none">Mapping Process <span id="ats_process"></span></th>
              <th onclick="atSort('task_name')"      style="cursor:pointer;user-select:none">Task Name <span id="ats_task_name"></span></th>
              <th onclick="atSort('assignee_name')"  style="cursor:pointer;user-select:none">Assignee <span id="ats_assignee_name"></span></th>
              <th onclick="atSort('enterprise_id')"  style="cursor:pointer;user-select:none">Ent. ID <span id="ats_enterprise_id"></span></th>
              <th onclick="atSort('turnaround_time')" style="cursor:pointer;user-select:none">TAT(min) <span id="ats_turnaround_time"></span></th>
              <th onclick="atSort('volume')"         style="cursor:pointer;user-select:none">Vol <span id="ats_volume"></span></th>
              <th onclick="atSort('due_date')"       style="cursor:pointer;user-select:none">Due Date <span id="ats_due_date"></span></th>
              <th onclick="atSort('status')"         style="cursor:pointer;user-select:none">Status <span id="ats_status"></span></th>
              <th onclick="atSort('priority')"       style="cursor:pointer;user-select:none">Priority <span id="ats_priority"></span></th>
              <th style="text-align:center;width:90px">Actions</th>
            </tr></thead>
            <tbody id="atTbody"></tbody>
          </table>
        </div>
      </div>
    </div>


    <!-- USERS -->
    <div class="vs" id="vs-users">
      <div class="panel" style="overflow:hidden;">
        <div class="ph" style="justify-content:space-between;flex-wrap:wrap;gap:8px;">
          <span class="pt">All Team Members</span>
          <span id="uCount" style="font-size:.75rem;color:var(--muted);align-self:center;"></span>
        </div>
        <!-- activity column headers -->
        <div class="u-divider" id="uActivityHeader" style="display:none;">
          <span style="flex:1"></span>
          <div class="u-activity" id="uDayLabels"></div>
        </div>
