        </div>
      </div>
      <!-- TAT Overload Warnings -->
      <div class="panel" id="aTatWarnPanel" style="margin-top:0;">
        <div class="ph" id="aTatWarnPh">
          <span class="pt" id="aTatWarnTitle">⏳ Loading TAT data…</span>
          <span id="aTatWarnSub" style="font-size:.75rem;color:var(--muted)">Members exceeding 540 mins TAT per day (9 hrs total)</span>
        </div>
